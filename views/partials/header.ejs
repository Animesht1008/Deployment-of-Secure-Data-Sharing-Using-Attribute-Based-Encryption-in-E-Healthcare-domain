<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || "E-Healthcare" %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
    <div class="container">
      <a class="navbar-brand" href="/">E-Healthcare Secure Share</a>
      <div class="d-flex gap-2">
        <% if (currentUser) { %>
          <span class="navbar-text text-white"><%= currentUser.name %> (<%= currentUser.role %>)</span>
          <a class="btn btn-sm btn-outline-light" href="/logout">Logout</a>
        <% } %>
      </div>
    </div>
  </nav>
  <main class="container pb-4">
