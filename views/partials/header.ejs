<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || "E-Healthcare" %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/site.css" rel="stylesheet">
</head>
<body class="<%= bodyClass || 'page-home' %> app-shell">
  <nav class="navbar navbar-expand-lg topbar mb-4">
    <div class="container-fluid px-4">
      <a class="navbar-brand" href="/">Secure E-Healthcare</a>
      <button class="navbar-toggler border border-light" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse justify-content-end" id="mainNav">
        <ul class="navbar-nav align-items-lg-center">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item hover-dropdown">
            <span class="nav-link">Patient</span>
            <div class="hover-dropdown-menu">
              <a href="/login/patient">Login</a>
              <a href="/signup/patient">Signup</a>
            </div>
          </li>
          <li class="nav-item hover-dropdown">
            <span class="nav-link">Doctor</span>
            <div class="hover-dropdown-menu">
              <a href="/login/doctor">Login</a>
              <a href="/signup/doctor">Signup</a>
            </div>
          </li>
          <li class="nav-item hover-dropdown">
            <span class="nav-link">Trusted Authority</span>
            <div class="hover-dropdown-menu">
              <a href="/login/ta">Login</a>
            </div>
          </li>
          <li class="nav-item hover-dropdown">
            <span class="nav-link">Cloud Admin</span>
            <div class="hover-dropdown-menu">
              <a href="/login/cloud">Login</a>
            </div>
          </li>
          <% if (currentUser) { %>
            <li class="nav-item ms-lg-2">
              <span class="navbar-text text-white"><%= currentUser.name %> (<%= currentUser.role %>)</span>
            </li>
            <li class="nav-item ms-lg-2">
              <a class="btn btn-sm btn-outline-light" href="/logout">Logout</a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>
  <main class="container main-content">
