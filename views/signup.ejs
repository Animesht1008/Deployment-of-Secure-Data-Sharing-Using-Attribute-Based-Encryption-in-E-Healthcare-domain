<%- include("partials/header", { title: role + " Signup", bodyClass: "page-signup" }) %>
<div class="card auth-card">
  <div class="card-header text-capitalize"><%= role %> Signup</div>
  <div class="card-body p-4">
    <form method="post" action="/signup/<%= role %>" class="row g-3">
      <div class="col-md-6"><input name="name" class="form-control" placeholder="Full Name" required></div>
      <div class="col-md-6"><input type="email" name="email" class="form-control" placeholder="Email Address" required></div>
      <div class="col-md-6"><input type="password" name="password" class="form-control" placeholder="Create Password" required></div>
      <div class="col-md-6"><input name="dob" class="form-control" placeholder="Date of Birth"></div>
      <div class="col-md-4"><input name="age" class="form-control" placeholder="Age"></div>
      <div class="col-md-4"><input name="gender" class="form-control" placeholder="Gender"></div>
      <div class="col-md-4"><input name="phone" class="form-control" placeholder="Phone"></div>
      <div class="col-12"><input name="address" class="form-control" placeholder="Address"></div>
      <% if (role === "doctor") { %>
        <div class="col-12"><input name="department" class="form-control" placeholder="Department" required></div>
      <% } %>
      <div class="col-12 d-grid"><button class="btn btn-primary">Create account</button></div>
      <div class="col-12 text-center">
        <small>Already registered? <a href="/login/<%= role %>">Login here</a></small>
      </div>
    </form>
  </div>
</div>
<%- include("partials/footer") %>
